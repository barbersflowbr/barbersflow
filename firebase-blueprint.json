{
  "entities": {
    "Barbearia": {
      "title": "Barbearia",
      "description": "Barbearia shop profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "password": { "type": "string" },
        "slug": { "type": "string" },
        "plan": { "type": "string" },
        "logo": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "email", "password", "slug", "plan", "createdAt"]
    },
    "Booking": {
      "title": "Booking",
      "description": "An appointment booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "barbeariaId": { "type": "string" },
        "barberId": { "type": "string" },
        "serviceId": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string" },
        "clientPhone": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["barberId", "serviceId", "clientName", "clientEmail", "clientPhone", "date", "time", "status", "barbeariaId", "createdAt"]
    }
  },
  "firestore": {
    "barbearias/{barbeariaId}": {
      "schema": "Barbearia",
      "description": "Barbearias collection"
    },
    "bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Bookings collection"
    }
  }
}
